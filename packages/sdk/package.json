    "test": "vitest run",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@open-os/a2a": "workspace:*",
    "@open-os/kernel": "workspace:*",
    "@open-os/mcp": "workspace:*",
    "@open-os/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
