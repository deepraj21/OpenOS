# SQLite (default). For production, use PostgreSQL: set provider in prisma/schema.prisma
# to postgresql and point DATABASE_URL at your instance, then run prisma migrate deploy.
DATABASE_URL="file:./prisma/registry.db"

# Comma-separated API keys for POST /api/agents (publish). When unset, publish is allowed
# without auth (local development only).
OPENOS_REGISTRY_API_KEYS=""
