{
  "name": "@open-os/registry",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate && DATABASE_URL=file:./prisma/registry.db prisma migrate deploy && next build",
    "lint": "next lint",
    "start": "next start -p 3001",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "db:migrate": "DATABASE_URL=file:./prisma/registry.db prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "vitest": "^2.1.8",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.18",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
