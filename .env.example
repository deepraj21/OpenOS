# LLM Providers (set whichever you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# CLI → registry (`openos publish` / `openos install`)
OPENOS_REGISTRY_URL=http://localhost:3001
OPENOS_REGISTRY_TOKEN=

# Registry server (see apps/registry/.env.example for DB + API keys)

# Cloud (Phase 3)
REDIS_URL=redis://localhost:6379
CLOUD_AUTH_SECRET=
